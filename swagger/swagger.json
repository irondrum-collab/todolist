{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoList API",
    "version": "1.0.0",
    "description": "TodoList 앱의 백엔드 REST API 명세서입니다. JWT Bearer Token 인증을 사용하며, 할 일 관리 및 사용자 인증 기능을 제공합니다."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "로컬 개발 서버"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "회원가입 및 로그인 인증 관련 엔드포인트"
    },
    {
      "name": "Users",
      "description": "사용자 정보 관련 엔드포인트"
    },
    {
      "name": "Todos",
      "description": "할 일 CRUD 관련 엔드포인트"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 액세스 토큰. 로그인 응답의 token 값을 사용합니다."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "email", "name", "theme", "language", "createdAt"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "사용자 고유 ID",
            "example": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "사용자 이메일 주소",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "description": "사용자 이름",
            "example": "홍길동"
          },
          "theme": {
            "type": "string",
            "enum": ["light", "dark"],
            "description": "UI 테마 설정",
            "example": "light"
          },
          "language": {
            "type": "string",
            "enum": ["ko", "en"],
            "description": "언어 설정",
            "example": "ko"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "계정 생성 일시",
            "example": "2026-05-28T00:00:00.000Z"
          }
        }
      },
      "Todo": {
        "type": "object",
        "required": [
          "id",
          "title",
          "isCompleted",
          "status",
          "categoryId",
          "userId",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "할 일 고유 ID",
            "example": 1
          },
          "title": {
            "type": "string",
            "description": "할 일 제목",
            "example": "프로젝트 기획서 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할 일 상세 설명",
            "example": "1분기 사업계획 포함"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "시작 날짜 (YYYY-MM-DD)",
            "example": "2026-05-28"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "종료 날짜 (YYYY-MM-DD)",
            "example": "2026-06-03"
          },
          "isCompleted": {
            "type": "boolean",
            "description": "완료 여부",
            "example": false
          },
          "status": {
            "type": "string",
            "enum": ["시작 전", "진행 중", "완료", "기한 초과", "진행 중 (날짜 없음)"],
            "description": "런타임 계산 상태값",
            "example": "진행 중"
          },
          "categoryId": {
            "type": "integer",
            "description": "카테고리 ID",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "description": "소유자 사용자 ID",
            "example": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "생성 일시",
            "example": "2026-05-28T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "최종 수정 일시",
            "example": "2026-05-28T00:00:00.000Z"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "에러 설명 메시지",
            "example": "요청을 처리하는 중 오류가 발생했습니다."
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["token", "user"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT 액세스 토큰",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입",
        "description": "이메일, 비밀번호, 이름으로 새 계정을 생성합니다. 이메일 중복 시 409를 반환합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 254,
                    "description": "RFC 5322 형식의 이메일 주소, 최대 254자",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "description": "8~128자, 영문·숫자·특수문자 각 1자 이상 포함",
                    "example": "Pass123!"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50,
                    "description": "사용자 이름, 1~50자",
                    "example": "홍길동"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["message"],
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "회원가입이 완료되었습니다."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "요청 유효성 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "유효성 오류 설명"
                }
              }
            }
          },
          "409": {
            "description": "이메일 중복",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "이미 사용 중인 이메일입니다"
                }
              }
            }
          },
          "500": {
            "description": "서버 내부 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "서버 내부 오류가 발생했습니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인",
        "description": "이메일과 비밀번호로 로그인하여 JWT 토큰과 사용자 정보를 반환받습니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "가입된 이메일 주소",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "description": "계정 비밀번호",
                    "example": "Pass123!"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                },
                "example": {
                  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                  "user": {
                    "id": 1,
                    "email": "user@example.com",
                    "name": "홍길동",
                    "theme": "light",
                    "language": "ko",
                    "createdAt": "2026-05-28T00:00:00.000Z"
                  }
                }
              }
            }
          },
          "401": {
            "description": "이메일 또는 비밀번호 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "이메일 또는 비밀번호가 올바르지 않습니다"
                }
              }
            }
          },
          "500": {
            "description": "서버 내부 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "서버 내부 오류가 발생했습니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me": {
      "put": {
        "tags": ["Users"],
        "summary": "내 정보 수정",
        "description": "인증된 사용자의 이름, 비밀번호, 테마, 언어 설정을 수정합니다. 모든 필드는 선택 사항입니다. 비밀번호 변경 시 currentPassword와 newPassword를 함께 전송해야 합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50,
                    "description": "변경할 이름, 1~50자",
                    "example": "새이름"
                  },
                  "currentPassword": {
                    "type": "string",
                    "description": "비밀번호 변경 시 필수. 현재 비밀번호",
                    "example": "OldPass123!"
                  },
                  "newPassword": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "description": "변경할 새 비밀번호, 8~128자. currentPassword와 함께 전송",
                    "example": "NewPass456@"
                  },
                  "theme": {
                    "type": "string",
                    "enum": ["light", "dark"],
                    "description": "UI 테마 설정",
                    "example": "dark"
                  },
                  "language": {
                    "type": "string",
                    "enum": ["ko", "en"],
                    "description": "언어 설정",
                    "example": "en"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "정보 수정 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["user"],
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                },
                "example": {
                  "user": {
                    "id": 1,
                    "email": "user@example.com",
                    "name": "새이름",
                    "theme": "dark",
                    "language": "en",
                    "createdAt": "2026-05-28T00:00:00.000Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "요청 유효성 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "유효성 오류 설명"
                }
              }
            }
          },
          "401": {
            "description": "미인증 또는 현재 비밀번호 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unauthorized": {
                    "summary": "토큰 없음·만료·유효하지 않음",
                    "value": {
                      "message": "인증이 필요합니다."
                    }
                  },
                  "wrongPassword": {
                    "summary": "현재 비밀번호 불일치",
                    "value": {
                      "message": "현재 비밀번호가 올바르지 않습니다"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "서버 내부 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "서버 내부 오류가 발생했습니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/todos": {
      "post": {
        "tags": ["Todos"],
        "summary": "할 일 등록",
        "description": "새 할 일을 생성합니다. categoryId를 지정하지 않으면 서비스 레이어에서 기본 카테고리 ID가 자동으로 적용됩니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "description": "할 일 제목, 1~100자 (필수)",
                    "example": "프로젝트 기획서 작성"
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1000,
                    "description": "할 일 상세 설명, 최대 1000자 (선택)",
                    "example": "1분기 사업계획 포함"
                  },
                  "categoryId": {
                    "type": "integer",
                    "description": "카테고리 ID (선택, 미지정 시 기본 카테고리 자동 적용)",
                    "example": 1
                  },
                  "startDate": {
                    "type": "string",
                    "format": "date",
                    "description": "시작 날짜, YYYY-MM-DD 형식 (선택)",
                    "example": "2026-05-28"
                  },
                  "endDate": {
                    "type": "string",
                    "format": "date",
                    "description": "종료 날짜, YYYY-MM-DD 형식, endDate >= startDate (선택)",
                    "example": "2026-06-03"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "할 일 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["todo"],
                  "properties": {
                    "todo": {
                      "$ref": "#/components/schemas/Todo"
                    }
                  }
                },
                "example": {
                  "todo": {
                    "id": 1,
                    "title": "프로젝트 기획서 작성",
                    "description": "1분기 사업계획 포함",
                    "startDate": "2026-05-28",
                    "endDate": "2026-06-03",
                    "isCompleted": false,
                    "status": "진행 중",
                    "categoryId": 1,
                    "userId": 1,
                    "createdAt": "2026-05-28T00:00:00.000Z",
                    "updatedAt": "2026-05-28T00:00:00.000Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "요청 유효성 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "유효성 오류 설명"
                }
              }
            }
          },
          "401": {
            "description": "미인증 (토큰 없음·만료·유효하지 않음)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "인증이 필요합니다."
                }
              }
            }
          },
          "500": {
            "description": "서버 내부 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "서버 내부 오류가 발생했습니다."
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Todos"],
        "summary": "할 일 목록 조회",
        "description": "인증된 사용자의 할 일 목록을 조회합니다. categoryId 또는 status 쿼리 파라미터로 필터링할 수 있습니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "categoryId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 1
            },
            "description": "카테고리 ID로 필터링 (선택)"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["시작 전", "진행 중", "완료", "기한 초과"],
              "example": "진행 중"
            },
            "description": "상태값으로 필터링 (선택)"
          }
        ],
        "responses": {
          "200": {
            "description": "할 일 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["todos"],
                  "properties": {
                    "todos": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Todo"
                      }
                    }
                  }
                },
                "example": {
                  "todos": [
                    {
                      "id": 1,
                      "title": "프로젝트 기획서 작성",
                      "description": "1분기 사업계획 포함",
                      "startDate": "2026-05-28",
                      "endDate": "2026-06-03",
                      "isCompleted": false,
                      "status": "진행 중",
                      "categoryId": 1,
                      "userId": 1,
                      "createdAt": "2026-05-28T00:00:00.000Z",
                      "updatedAt": "2026-05-28T00:00:00.000Z"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "미인증 (토큰 없음·만료·유효하지 않음)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "인증이 필요합니다."
                }
              }
            }
          },
          "500": {
            "description": "서버 내부 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "서버 내부 오류가 발생했습니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/todos/{id}": {
      "put": {
        "tags": ["Todos"],
        "summary": "할 일 수정",
        "description": "지정한 ID의 할 일을 수정합니다. 모든 필드는 선택 사항이며, description·startDate·endDate는 null 전송으로 삭제할 수 있습니다. 본인 소유의 할 일만 수정 가능합니다.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "example": 1
            },
            "description": "수정할 할 일의 ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
